{
  "type": "full_stack",
  "backend": {
    "path": ".",
    "type": "fastapi",
    "entry_point": "underwriting_system/api.py",
    "start": "uvicorn underwriting_system.api:app --host 0.0.0.0 --port $PORT"
  },
  "frontend": {
    "path": "frontend",
    "type": "vite",
    "build": "npm install && npm run build",
    "dist": "dist",
    "api_base": "/api"
  }
}
